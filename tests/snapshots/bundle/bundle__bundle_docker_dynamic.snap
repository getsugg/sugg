---
source: tests/bundle.rs
expression: "normalize(docker, &dir)"
---
//#region virtual:i18n/docker
const container_desc = "Running container";
//#endregion
//#region tests/fixtures/completions/docker/__v_dyn_docker.ts
const __dyn_docker_ps_args = async () => {
	return (await exec("docker ps --format '{{.Names}}'")).split("\n").filter(Boolean).map((name) => ({
		display: name,
		description: container_desc
	}));
};
//#endregion
export { __dyn_docker_ps_args };
