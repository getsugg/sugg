// === pnpm ===
//#region tests/fixtures/completions/_lib.ts
const a = "外部引入的变量";
//#endregion
//#region sugg
const readJson = async (path) => {
	const content = await globalThis.__readFile(path);
	if (!content) return {};
	try {
		return JSON.parse(content);
	} catch {
		return {};
	}
};
globalThis.__exec;
globalThis.__execFile;
globalThis.__scanPath;
globalThis.__readFile;
globalThis.__ui;
