//#region tests/fixtures/completions/__v_dyn_pnpm.ts
const __dyn_pnpm_run_args = async () => {
	const scripts = (await readJson("package.json")).scripts || {};
	return Object.entries(scripts).map(([name, cmd]) => ({
		display: name,
		description: `运行指令 ${a}: ${cmd}`
	}));
};
