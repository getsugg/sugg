// === pnpm ===
//#region virtual:env
const readJson = async (path) => {
	const content = await globalThis.readFile(path);
	if (!content) return {};
	try {
		return JSON.parse(content);
	} catch {
		return {};
	}
};
//#endregion
//#region tests/fixtures/completions/_lib.ts
const a = "外部引入的变量";
//#endregion
//#region tests/fixtures/completions/__v_dyn_pnpm.ts
const __dyn_pnpm_run_args = async () => {
	const scripts = (await readJson("package.json")).scripts || {};
	return Object.entries(scripts).map(([name, cmd]) => ({
		display: name,
		description: `运行指令 ${a}: ${cmd}`
	}));
};
//#endregion
export { __dyn_pnpm_run_args };

// === testkit ===
//#region tests/fixtures/completions/__v_dyn_testkit.ts
const __dyn_sharedDynamic = async () => {
	return [
		"shared-a",
		"shared-b",
		"shared-c"
	];
};
const __dyn_testkit_opts_options_d_args = async () => {
	return [
		"item1",
		"item2",
		"item3"
	];
};
const __dyn_testkit_optsinfo_args = async (ctx) => {
	const lines = [];
	const opts = ctx.options;
	if (opts["-g"]) lines.push("global:true");
	if (opts["--config"]) lines.push(`config:${opts["--config"].join(",")}`);
	if (opts["--cwd"]) lines.push(`cwd:${opts["--cwd"].join(",")}`);
	if (opts["--exclude"]) lines.push(`exclude:${opts["--exclude"].join(",")}`);
	if (lines.length === 0) lines.push("(no options)");
	return lines.map((s) => ({
		display: s,
		value: s
	}));
};
const __dyn_testkit_hybrid_args = async () => {
	return [
		"file1.txt",
		"file2.txt",
		"file3.txt"
	];
};
const __dyn_testkit_logdemo_args = async (ctx) => {
	const prefix = ctx.prefix ?? "";
	if (prefix.startsWith("bad-")) throw new Error(`❌ Invalid prefix detected: "${prefix}" — please remove the leading "bad-"`);
	else {
		log("[DEBUG] prefix=", prefix);
		log("[INFO] configuration loaded successfully");
	}
	return [
		{
			display: "alpha",
			value: "alpha",
			description: "First item"
		},
		{
			display: "beta",
			value: "beta",
			description: "Second item"
		},
		{
			display: "gamma",
			value: "gamma",
			description: "Third item"
		}
	];
};
//#endregion
export { __dyn_sharedDynamic, __dyn_testkit_hybrid_args, __dyn_testkit_logdemo_args, __dyn_testkit_opts_options_d_args, __dyn_testkit_optsinfo_args };
