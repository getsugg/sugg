---
source: tests/bundle.rs
expression: "normalize(combined, &dir)"
---
// === bun ===
//#region virtual:i18n/bun
const suggestion_file = "文件";
const suggestion_global_installed = "全局已安装";
const suggestion_installed = "已安装";
const suggestion_package_bin = "包可执行文件";
const suggestion_package_from_registry = "来自注册表的包";
const suggestion_script = "脚本";
//#endregion
//#region sugg
const readJson = async (path) => {
	const content = await globalThis.__readFile(path);
	if (!content) return {};
	try {
		return JSON.parse(content);
	} catch {
		return {};
	}
};
const exec = globalThis.__exec;
globalThis.__execFile;
const scanPath = globalThis.__scanPath;
globalThis.__readFile;
globalThis.__ui;
//#endregion
//#region tests/fixtures/completions/bun/__v_dyn_bun.ts
async function getCompletes(type) {
	try {
		const out = await exec(`bun getcompletes ${type}`);
		if (type === "z") return out.trim().split("\n").filter((line) => line.includes("	")).map((line) => line.split("	")[0]);
		else return out.trim().split(/\s+/).filter(Boolean);
	} catch {
		return [];
	}
}
async function getScriptNames() {
	return (await getCompletes("z")).map((s) => ({
		display: s,
		description: suggestion_script
	}));
}
async function getBinNames() {
	return (await getCompletes("b")).map((b) => ({
		display: b,
		description: suggestion_package_bin
	}));
}
async function getScriptFiles(ctx) {
	return (await scanPath(ctx.prefix)).filter((f) => /\.(ts|js|tsx|jsx|mjs|cjs)$/i.test(f.display) || f.isDir);
}
async function getTestFiles(ctx) {
	return (await scanPath(ctx.prefix)).filter((f) => /\.(test|spec)\.(ts|js|tsx|jsx)$/i.test(f.display) || ctx.prefix !== "" && f.isDir);
}
async function getInstalledPackages() {
	const pkg = await readJson("package.json");
	const deps = {
		...pkg.dependencies,
		...pkg.devDependencies
	};
	return Object.keys(deps).map((name) => ({
		display: name,
		description: suggestion_installed
	}));
}
async function getGlobalPackages() {
	try {
		return (await exec("bun pm ls -g")).trim().split("\n").slice(1).map((line) => line.replace(/^[├└][─ ]{2,}\s+/, "").trim()).filter(Boolean).map((name) => name.replace(/@[^@]+$/, "")).filter((name) => name.length > 0).map((name) => ({
			display: name,
			description: suggestion_global_installed
		}));
	} catch {
		return [];
	}
}
async function getAddPackages(ctx) {
	try {
		return (await exec(`bun getcompletes a ${ctx.prefix}`)).trim().split(/\s+/).filter(Boolean).map((name) => ({
			display: name,
			description: suggestion_package_from_registry
		}));
	} catch {
		return [];
	}
}
const __dyn_pmSubCommands_why_args = async () => getInstalledPackages();
const __dyn_pmSubCommands_pkg_args = async (ctx) => {
	return [
		"get",
		"set",
		"delete",
		"fix"
	].filter((c) => c.startsWith(ctx.prefix));
};
const __dyn_pmSubCommands_trust_args = async () => getInstalledPackages();
const __dyn_bunCommands_run_args = async (ctx) => {
	let [scripts, bins, files] = await Promise.all([
		getScriptNames(),
		getBinNames(),
		getScriptFiles(ctx)
	]);
	if (ctx.prefix) {
		scripts = scripts.filter((s) => s.display.startsWith(ctx.prefix));
		bins = bins.filter((b) => b.display.startsWith(ctx.prefix));
	}
	if (scripts.length + bins.length > 0) {
		if (ctx.prefix === "") files = files.filter((f) => !f.isDir);
		files = files.map((f) => ({
			...f,
			description: suggestion_file
		}));
	}
	return [
		...scripts,
		...files,
		...bins
	];
};
const __dyn_bunCommands_test_args = async (ctx) => getTestFiles(ctx);
const __dyn_bunCommands_install_args = async (ctx) => getAddPackages(ctx);
const __dyn_bunCommands_add_args = async (ctx) => getAddPackages(ctx);
const __dyn_bunCommands_remove_args = async (ctx) => {
	if (ctx.options["-g"] === true || ctx.options["--global"] === true) return getGlobalPackages();
	return getInstalledPackages();
};
const __dyn_bunCommands_update_args = async () => getInstalledPackages();
const __dyn_bunCommands_why_args = async () => getInstalledPackages();
const __dyn_bunCommands_build_args = async (ctx) => getScriptFiles(ctx);
//#endregion
export { __dyn_bunCommands_add_args, __dyn_bunCommands_build_args, __dyn_bunCommands_install_args, __dyn_bunCommands_remove_args, __dyn_bunCommands_run_args, __dyn_bunCommands_test_args, __dyn_bunCommands_update_args, __dyn_bunCommands_why_args, __dyn_pmSubCommands_pkg_args, __dyn_pmSubCommands_trust_args, __dyn_pmSubCommands_why_args };

// === docker ===
