// === git ===
//#region sugg
const exec = globalThis.__exec;
globalThis.__execFile;
globalThis.__scanPath;
globalThis.__readFile;
globalThis.__ui;
//#endregion
//#region tests/fixtures/completions/git/__v_dyn_git.ts
const getRemotes = async () => {
	try {
		return (await exec("git remote")).split(/\r?\n/).map((s) => s.trim()).filter(Boolean);
	} catch {
		return [];
	}
};
const getBranches = async () => {
	try {
		return (await exec("git branch --format=%(refname:short)")).split(/\r?\n/).map((s) => s.trim()).filter(Boolean);
	} catch {
		return [];
	}
};
const __dyn_git_add_args_items = async (ctx) => {
	if (ctx.positionals.length === 0) return ["."];
	return [];
};
const __dyn_git_checkout_args = async () => {
	return await getBranches();
};
const __dyn_git_branch_args = async () => {
	return await getBranches();
};
const __dyn_git_push_args_items = async (ctx) => {
	if (ctx.positionals.length === 0) return getRemotes();
	if (ctx.positionals.length === 1) return getBranches();
	return [];
};
const __dyn_git_pull_args_items = async (ctx) => {
	if (ctx.positionals.length === 0) return getRemotes();
	if (ctx.positionals.length === 1) return getBranches();
	return [];
};
const __dyn_git_remote_add_args_items = async (ctx) => {
	if (ctx.positionals.length === 0) return getRemotes();
	if (ctx.positionals.length === 1) return [`git@github.com:user/${ctx.positionals[0]}.git`, `https://github.com/user/${ctx.positionals[0]}.git`];
	return [];
};
const __dyn_git_remote_rename_args_items = async (ctx) => {
	if (ctx.positionals.length === 0) return getRemotes();
	return [];
};
const __dyn_git_remote_remove_args = async () => {
	return getRemotes();
};
//#endregion
export { __dyn_git_add_args_items, __dyn_git_branch_args, __dyn_git_checkout_args, __dyn_git_pull_args_items, __dyn_git_push_args_items, __dyn_git_remote_add_args_items, __dyn_git_remote_remove_args, __dyn_git_remote_rename_args_items };

// === greet_dynamic ===
