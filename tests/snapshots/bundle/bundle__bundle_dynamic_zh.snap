// === testkit ===
globalThis.__exec;
globalThis.__execFile;
globalThis.__scanPath;
globalThis.__readFile;
const ui = globalThis.__ui;
//#endregion
//#region tests/fixtures/completions/__v_dyn_testkit.ts
const __dyn_sharedDynamic = async () => {
	return [
		"shared-a",
		"shared-b",
		"shared-c"
	];
};
const __dyn_testkit_opts_options_d_args = async () => {
	return [
		"item1",
		"item2",
		"item3"
	];
};
const __dyn_testkit_optsinfo_args = async (ctx) => {
	const lines = [];
	const opts = ctx.options;
	if (opts["-g"]) lines.push("global:true");
	if (opts["--config"]) lines.push(`config:${opts["--config"].join(",")}`);
	if (opts["--cwd"]) lines.push(`cwd:${opts["--cwd"].join(",")}`);
	if (opts["--exclude"]) lines.push(`exclude:${opts["--exclude"].join(",")}`);
	if (lines.length === 0) lines.push("(no options)");
	return lines.map((s) => ({
		display: s,
		value: s
	}));
};
const __dyn_testkit_hybrid_args = async () => {
	return [
		"file1.txt",
		"file2.txt",
		"file3.txt"
	];
};
const __dyn_testkit_logdemo_args = async (ctx) => {
	const prefix = ctx.prefix ?? "";
	if (prefix.startsWith("bad-")) throw new Error(`❌ Invalid prefix detected: "${prefix}" — please remove the leading "bad-"`);
	else {
		ui.log("[DEBUG] prefix=", prefix);
		ui.log("[INFO] configuration loaded successfully");
	}
	return [
		{
			display: "alpha",
			value: "alpha",
			description: "First item"
		},
		{
			display: "beta",
			value: "beta",
			description: "Second item"
		},
		{
			display: "gamma",
			value: "gamma",
			description: "Third item"
		}
	];
};
const __dyn_testkit_multiValueOpt_options_exclude_args_items = () => [
	"a",
	"b",
	"c"
];
const __dyn_testkit_dynamicPositional_args_items = async (ctx) => {
	if (ctx.positionals.length === 0) return [
		"origin",
		"upstream",
		"mine"
	];
	if (ctx.positionals.length === 1) return [`url-for:${ctx.positionals[0]}`, "https://github.com/x"];
	return [];
};
//#endregion
export { __dyn_sharedDynamic, __dyn_testkit_dynamicPositional_args_items, __dyn_testkit_hybrid_args, __dyn_testkit_logdemo_args, __dyn_testkit_multiValueOpt_options_exclude_args_items, __dyn_testkit_opts_options_d_args, __dyn_testkit_optsinfo_args };
