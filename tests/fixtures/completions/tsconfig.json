{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext"],
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": [],
    "paths": {}
  },
  "include": [
    "**/*.ts",
    "**/*.js",
    ".sugg/i18n.d.ts",
    "../../../crates/sugg-engine/assets/init/.sugg/sugg.d.ts"
  ],
  "exclude": ["node_modules"]
}
